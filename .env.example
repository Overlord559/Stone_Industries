# Root deploy (Cloudflare Pages, Netlify). Use /Stone_Industries/ only for GitHub Pages mirror builds.

VITE_BASE_PATH=/



# Supabase inquiry capture (public anon key only — never service role)

VITE_SUPABASE_URL=

VITE_SUPABASE_ANON_KEY=



# Optional privacy-safe analytics (free tiers — leave blank to disable)

VITE_GA_MEASUREMENT_ID=

VITE_CLARITY_PROJECT_ID=



# Cloudflare Pages Functions only — NEVER prefix with VITE_ (server-side only)

# Set in Cloudflare dashboard → Settings → Environment variables → Functions

# SUPABASE_URL=

# SUPABASE_SERVICE_ROLE_KEY=

# STONE_ADMIN_TOKEN=

# RESEND_API_KEY=

# RESEND_FROM=

# STONE_NOTIFY_EMAIL=edward@stoneindustriesusa.com

# HUBSPOT_PRIVATE_APP_TOKEN=

